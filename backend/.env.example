# ==========================================
# MaintainIQ Backend - Environment Variables
# Copy this file to .env and fill in real values.
# The database is local SQLite - no install, no Docker, no Atlas needed.
# ==========================================

# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database (SQLite via Prisma) - a local file, created automatically by
# `npx prisma migrate dev`. No separate database server required.
DATABASE_URL="file:./dev.db"

# JWT
JWT_SECRET=replace_this_with_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# Cloudinary (image uploads for issue evidence photos)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AI Issue Triage - pick ONE provider and set AI_PROVIDER accordingly
AI_PROVIDER=gemini
# Gemini
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash
# OpenAI (used if AI_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini

# Rate limiting
RATE_LIMIT_WINDOW_MIN=15
RATE_LIMIT_MAX=300
